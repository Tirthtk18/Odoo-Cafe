{
  "compilerOptions": {
    "checkJs": false,
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": false,
    "allowJs": true,
    "jsx": "react-jsx",
    "strict": false
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
